#!/usr/bin/env bash
set -euo pipefail
CLAUDE_MODEL="sonnet"
source "$(dirname "$0")/lib/common.sh"

parse_model_flags "$@"
set -- "${REMAINING_ARGS[@]}"

USAGE="Usage: regexfor \"description of what to match\"

Generates a regex from a plain English description."

text="$(resolve_input "$USAGE" "$@")"

ask_haiku "Generate a regular expression for the following description. Output exactly:
1. The regex pattern
2. A brief explanation of each part
3. Two example matches and one non-match

Be concise.

Description: ${text}"
