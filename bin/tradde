#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib/common.sh"

USAGE="Usage: tradde \"text to translate\"

Translates text from any language to German.
Outputs the translation and its IPA transcription."

text="$(resolve_input "$USAGE" "$@")"

ask_haiku "Translate the following text to German. Output exactly two lines:
1. The German translation
2. The IPA (International Phonetic Alphabet) transcription of the German translation

No labels, no extra text, no explanations. Just the two lines.

Text: ${text}"
