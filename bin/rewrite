#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib/common.sh"

parse_model_flags "$@"
set -- "${REMAINING_ARGS[@]}"

USAGE="Usage: rewrite [--tone TONE] \"text to rewrite\"

Rewrites text in a given tone.
Tones: formal, casual, concise, friendly, professional, academic
Default tone: concise"

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  echo "$USAGE"
  exit 0
fi

tone="concise"
if [ "${1:-}" = "--tone" ]; then
  tone="$2"
  shift 2
fi

text="$(resolve_input "$USAGE" "$@")"

ask_haiku "Rewrite the following text in a ${tone} tone. Output only the rewritten text, nothing else.

${text}"
