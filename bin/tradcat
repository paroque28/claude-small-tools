#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib/common.sh"

USAGE="Usage: tradcat \"text to translate\"

Translates text from any language to Catalan.
Outputs the translation and its IPA transcription."

text="$(resolve_input "$USAGE" "$@")"

ask_haiku "Translate the following text to Catalan. Output exactly two lines:
1. The Catalan translation
2. The IPA (International Phonetic Alphabet) transcription of the Catalan translation

No labels, no extra text, no explanations. Just the two lines.

Text: ${text}"
