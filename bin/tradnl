#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib/common.sh"

USAGE="Usage: tradnl \"text to translate\"

Translates text from any language to Dutch.
Outputs the translation and its IPA transcription."

text="$(resolve_input "$USAGE" "$@")"

ask_haiku "Translate the following text to Dutch. Output exactly two lines:
1. The Dutch translation
2. The IPA (International Phonetic Alphabet) transcription of the Dutch translation

No labels, no extra text, no explanations. Just the two lines.

Text: ${text}"
